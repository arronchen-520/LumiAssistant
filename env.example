# ── Groq (语音转文字 / Speech-to-Text) ─────────────────────────────────────
# 免费获取: https://console.groq.com — 仅用于 Whisper 语音转写
GROQ_API_KEY=your_groq_key_here

# ─────────────────────────────────────────────────────────────────────────────
# LLM 提供商配置 (LLM Provider Configuration)
# 选择一个提供商，填写对应配置 (Choose one provider and fill in its config)
# ─────────────────────────────────────────────────────────────────────────────

# LLM_PROVIDER 选项 | Options:
#   ollama  → 本地运行，完全私密 (local, fully private) [default]
#   groq    → Groq 云端 LLM API，速度极快，有免费额度 (fast, free tier)
#   openai  → OpenAI API (GPT-4o-mini 等)
#   custom  → 任意 OpenAI-compatible 端点 (any compatible endpoint)
LLM_PROVIDER=ollama

# 模型名称 | Model name
#   ollama: llama3.2, mistral, qwen2.5, gemma3, phi4 …
#   groq:   llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b …
#   openai: gpt-4o-mini, gpt-4o …
LLM_MODEL=llama3.2

# API 密钥 | API Key
#   ollama: 留空或 "ollama" (leave blank or "ollama")
#   groq:   从 console.groq.com 获取 (from console.groq.com)
#   openai: 从 platform.openai.com 获取
LLM_API_KEY=

# API 端点 | Base URL (仅 ollama / custom 需要修改)
LLM_BASE_URL=http://localhost:11434/v1

# ── 语音识别语言 (STT Language) ─────────────────────────────────────────────
# 留空 = 自动检测 (blank = auto-detect, recommended)
# 强制指定: zh | en | ja | ko | fr | de | es …
STT_LANGUAGE=
